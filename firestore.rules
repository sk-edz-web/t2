rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. User Profiles Collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId)
                    && incoming().uid == request.auth.uid
                    && incoming().name is string && incoming().name.size() <= 100
                    && incoming().username is string && incoming().username.size() <= 50;
      allow update: if isSignedIn() && isOwner(userId)
                    && incoming().uid == existing().uid
                    && incoming().username == existing().username
                    && incoming().name is string && incoming().name.size() <= 100;
      allow delete: if isOwner(userId);
    }

    // 2. Skills Collection
    match /skills/{skillId} {
      allow read: if true;
      allow create: if isSignedIn()
                    && incoming().title is string && incoming().title.size() <= 150
                    && incoming().description is string && incoming().description.size() <= 1000;
      allow update: if isSignedIn();
      allow delete: if isSignedIn();

      // Nested Reviews Subcollection
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn()
                      && incoming().text is string && incoming().text.size() <= 1000
                      && incoming().rating is int && incoming().rating >= 1 && incoming().rating <= 5;
        allow update, delete: if isSignedIn();
      }
    }
  }
}
